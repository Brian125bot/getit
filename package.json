{
  "name": "getit",
  "version": "2.0.0",
  "description": "Lightweight terminal-native Man-in-the-Loop workspace agent",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "getit": "./dist/src/index.js"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=8.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js dist/src/index.js",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "prepublishOnly": "npm run build",
    "test": "tsc && node --test dist/tests/*.test.js"
  },
  "keywords": [
    "terminal",
    "agent",
    "workspace",
    "llm",
    "cli",
    "openrouter",
    "security",
    "man-in-the-loop",
    "mitl",
    "ai",
    "automation"
  ],
  "author": "Brian Laposa <creetacticalgenius@gmail.com>",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Brian125bot/getit.git"
  },
  "bugs": {
    "url": "https://github.com/Brian125bot/getit/issues"
  },
  "homepage": "https://github.com/Brian125bot/getit#readme",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  }
}
